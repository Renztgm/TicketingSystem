generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]

  @@map("users")
}

model Ticket {
  id          String   @id
  title       String
  description String
  priority    Priority @default(MEDIUM)
  category    Category @default(GENERAL)
  status      Status   @default(OPEN)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tickets")
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Category {
  GENERAL
  BUG
  FEATURE_REQUEST
  ACCOUNT
  BILLING
  OTHER
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}